<?xml version="1.0"?>
<robot name="simple_robot">
<link name="world"/>
<joint name="fixed" type="fixed">
<parent link="world"/>
<child link="base_link"/>
</joint>
<link name="base_link">
<visual>
<geometry>
<cylinder length="0.05" radius="0.2"/>
</geometry>
<!--origin of the reference frame of the visual element with respect to the reference frame of the link -->
<!-- rpy - r is roll, p is pitch, y is yaw -->
<!-- xzy - x, y, z are offsets -->
<origin rpy = "0 0 0" xyz = "0 0 0" />
<material name = "yellow">
<color rgba = "1 1 0 1" />
</material>
</visual>
<collision>
<geometry>
<cylinder length="0.05" radius="0.2"/>
</geometry>
<!--origin of the reference frame of the visual element with respect to the reference frame of the link -->
<!-- rpy - r is roll, p is pitch, y is yaw -->
<!-- xzy - x, y, z are offsets -->
<origin rpy = "0 0 0" xyz = "0 0 0" />
</collision>
</link>
<joint name="joint_1" type="revolute">
<parent link="base_link"/>
<child link="first_link"/>
<origin xyz="0 0 0.025"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="-2.2" upper="2.2" />
</joint>
<link name="first_link">
<visual>
<geometry>
<cylinder length="0.5" radius="0.04"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 0.25"/>
<material name="blue">
<color rgba="0 0 1 1"/>
</material>
</visual>
<collision>
<geometry>
<cylinder length="0.5" radius="0.04"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 0.25"/>
</collision>
</link>
<joint name="joint_2" type="revolute">
<parent link="first_link"/>
<child link="second_link"/>
<origin xyz="0 0 0.5" rpy="1.57079633 0 0"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="-2.2" upper="2.2" />
</joint>
<link name="second_link">
<visual>
<geometry>
<box size="0.5 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0.25 0 0"/>
<material name="green">
<color rgba="0 1 0 1"/>
</material>
</visual>
<collision>
<geometry>
<box size="0.5 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0.25 0 0"/>
</collision>
</link>
<joint name="joint_3" type="revolute">
<parent link="second_link"/>
<child link="third_link"/>
<origin xyz="0.5 0 0"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="-2.2" upper="2.2" />
</joint>
<link name="third_link">
<visual>
<geometry>
<box size="0.5 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0.25 0 0"/>
<material name="yellow">
<color rgba="1 1 0 1"/>
</material>
</visual>
<collision>
<geometry>
<box size="0.5 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0.25 0 0"/>
</collision>
</link>
<joint name="joint_4" type="revolute">
<parent link="third_link"/>
<child link="fourth_link"/>
<origin xyz="0.5 0 0"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="-2.2" upper="2.2" />
</joint>
<link name="fourth_link">
<visual>
<geometry>
<box size="0.1 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0.05 0 0"/>
<material name="blue">
<color rgba="0 0 1 1"/>
</material>
</visual>
<collision>
<geometry>
<box size="0.1 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0.05 0 0"/>
</collision>
</link>
<joint name="joint_final" type="revolute">
<parent link="fourth_link"/>
<child link="hand"/>
<origin xyz="0.1 0 0" rpy="0 1.57079633 0"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="-2.2" upper="2.2" />
</joint>
<link name="hand">
<visual>
<geometry>
<box size="0.4 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 0.05"/>
<material name="red">
<color rgba="1 0 0 1"/>
</material>
</visual>
<collision>
<geometry>
<box size="0.4 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 0.05"/>
</collision>
</link>
<joint name="finger1_joint" type="prismatic">
<parent link="hand"/>
<child link="finger1"/>
<origin xyz="0 0 0.2" rpy="0 -1.57079633 0"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="0" upper="0.2" />
</joint>
<link name="finger1">
<visual>
<geometry>
<box size="0.2 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 0.05"/>
<material name="red">
<color rgba="1 0 0 1"/>
</material>
</visual>
<collision>
<geometry>
<box size="0.2 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 0.05"/>
</collision>
</link>
<joint name="finger2_joint" type="prismatic">
<parent link="hand"/>
<child link="finger2"/>
<origin xyz="0 0 0.2" rpy="0 -1.57079633 0"/>
<axis xyz="0 0 1"/>
<limit effort="300" velocity="2.0" lower="-0.2" upper="0" />
</joint>
<link name="finger2">
<visual>
<geometry>
<box size="0.2 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 -0.05"/>
<material name="red">
<color rgba="1 0 0 1"/>
</material>
</visual>
<collision>
<geometry>
<box size="0.2 0.1 0.1"/>
</geometry>
<origin rpy="0 0 0" xyz="0 0 -0.05"/>
</collision>
</link>
</robot>

